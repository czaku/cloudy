{
  "name": "cloudy",
  "version": "0.1.0",
  "description": "AI orchestration tool - decompose goals into tasks, route phases across local CLIs or APIs, and validate with deterministic + AI checks",
  "type": "module",
  "bin": {
    "cloudy": "./dist/bin/cloudy.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "prepare": "npm run build",
    "postinstall": "cd node_modules/@vykeai/fed && bun build src/index.ts --outfile dist/index.js --target node --format esm 2>/dev/null || true",
    "build": "npm run build:client && tsc",
    "build:client": "esbuild src/dashboard/client/index.tsx --bundle --minify --outfile=dist/dashboard/bundle.js --format=iife --platform=browser --loader:.css=css",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "cloudy": "node dist/bin/cloudy.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "orchestrator",
    "task-runner",
    "ai",
    "cli"
  ],
  "license": "MIT",
  "author": "vykeai",
  "repository": {
    "type": "git",
    "url": "https://github.com/vykeai/cloudy.git"
  },
  "homepage": "https://github.com/vykeai/cloudy#readme",
  "bugs": {
    "url": "https://github.com/vykeai/cloudy/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@clack/prompts": "^1.0.1",
    "omnai": "file:../omnai/packages/core",
    "@vykeai/fed": "github:vykeai/fed",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "glob": "^13.0.6",
    "ink": "^5.1.0",
    "open": "^11.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "esbuild": "^0.24.0",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "vitest": "^3.0.5"
  }
}
